{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyON9B2NBWgPo9M4/1lcKa/Q"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["Goal is to create docs in the form:\n","```\n","\"id\": \"ingredient_egg\", \"type\": \"ingredient_profile\",\n"," \"ingredient\": \"egg\",Flavor descriptors: chicken,\n"," characteristic odor similar to acetaldehyde, civet,\n","  wild, green bean, sweet, unpleasant and irritating odor, unpleasant odor of wild radish, cabbage-like,\n","   unpleasant odor in high concentration but pleasant\n","   in dilute solution., fecal\\n\\nThese aroma\n","\n","   compounds define the characteristic flavor of egg.\"\n","\n","```\n","\n","We will do this from the data that we collected from food -> odorant maps\n","\n"],"metadata":{"id":"Vnv9pcFoPJp-"}},{"cell_type":"code","source":["from google.colab import drive\n","drive.mount('/content/drive')\n","\n","DATA_DIR = \"/content/drive/MyDrive/Culinary Agent/rag_docs\""],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LffZoQlbPr5_","executionInfo":{"status":"ok","timestamp":1773389537985,"user_tz":420,"elapsed":13497,"user":{"displayName":"Arin Agarwal","userId":"16343823264529643708"}},"outputId":"b5c45e39-1845-4b53-ad3a-7f3e88ba2f85"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"code","source":["import json\n","import os\n","\n","def normalize(name):\n","    return name.lower().strip()\n","\n","# -----------------------\n","# Load food -> odorants\n","# -----------------------\n","\n","FOOD_TO_ODORANT_PATH = os.path.join(DATA_DIR, \"food_to_odorants.json\")\n","\n","with open(FOOD_TO_ODORANT_PATH, \"r\") as f:\n","    raw_food_to_odorant = json.load(f)\n","\n","food_to_odorant = {\n","    normalize(food): odorants\n","    for food, odorants in raw_food_to_odorant.items()\n","}\n","\n","# -----------------------\n","# Build RAG documents\n","# -----------------------\n","\n","rag_docs = []\n","\n","for food, odorants in food_to_odorant.items():\n","\n","    odorant_names = []\n","    descriptors = []\n","\n","    for o in odorants:\n","\n","        if \"name\" in o:\n","            odorant_names.append(normalize(o[\"name\"]))\n","\n","        if \"descriptors\" in o and o[\"descriptors\"]:\n","            descriptors.extend(o[\"descriptors\"])\n","\n","    descriptors = list(set(descriptors))\n","\n","    text = f\"\"\"\n","Ingredient: {food}\n","\n","Key odorants: {\", \".join(odorant_names[:6])}\n","\n","Flavor descriptors: {\", \".join(descriptors[:10])}\n","\n","These aroma compounds define the characteristic flavor of {food}.\n","\"\"\"\n","\n","    rag_docs.append({\n","        \"id\": f\"ingredient_{food}\",\n","        \"type\": \"ingredient_profile\",\n","        \"ingredient\": food,\n","        \"text\": text.strip()\n","    })\n","\n","# -----------------------\n","# Save JSONL file\n","# -----------------------\n","\n","OUTPUT_PATH = os.path.join(DATA_DIR, \"ingredient_flavor_docs.jsonl\")\n","\n","with open(OUTPUT_PATH, \"w\") as f:\n","    for doc in rag_docs:\n","        f.write(json.dumps(doc) + \"\\n\")\n","\n","print(f\"Saved {len(rag_docs)} RAG documents to {OUTPUT_PATH}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"BJZCR9NwPbOm","executionInfo":{"status":"ok","timestamp":1773390114513,"user_tz":420,"elapsed":276,"user":{"displayName":"Arin Agarwal","userId":"16343823264529643708"}},"outputId":"c07b657a-0b20-4e8e-eae9-7878df830da6"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Saved 605 RAG documents to /content/drive/MyDrive/Culinary Agent/rag_docs/ingredient_flavor_docs.jsonl\n"]}]},{"cell_type":"markdown","source":["We will now create docs of the form\n","```\n","Odorant: 2,5-dimethylpyrazine\n","\n","Aroma descriptors:\n","roasted, nutty, cocoa-like, medicinal.\n","\n","This odorant appears in roasted foods such as coffee, cocoa,\n","roast beef, and toasted nuts.\n","\n","Because it is shared across many roasted ingredients,\n","it contributes to flavor compatibility between them.\n","```\n","\n","These will tell us what characteristics the odorants have in a rag-friendly format. Warning: This takes around 10-15 mins to run since we are invoking an LLM for each of ~500 odorants."],"metadata":{"id":"hQENQ2OZR3Ya"}},{"cell_type":"code","source":["import json\n","import os\n","from groq import Groq\n","\n","DATA_DIR = \"/content/drive/MyDrive/Culinary Agent/rag_docs\"\n","INPUT_PATH = os.path.join(DATA_DIR, \"odorants_to_foods.json\")\n","OUTPUT_PATH = os.path.join(DATA_DIR, \"odorant_docs.jsonl\")\n","\n","client = Groq()\n","\n","def normalize(x):\n","    return x.lower().strip()\n","\n","\n","def generate_food_category(descriptors, foods):\n","\n","    descriptors = descriptors[:5]\n","    foods = foods[:6]\n","\n","    prompt = f\"\"\"\n","Descriptors: {\", \".join(descriptors)}\n","Foods: {\", \".join(foods)}\n","\n","Fill the blanks:\n","\n","This odorant appears in <BLANK> foods such as {\", \".join(foods)}.\n","\n","Because it is shared across many <BLANK> ingredients,\n","it contributes to flavor compatibility between them.\n","\n","Return ONLY the two words that replace <BLANK> separated by a comma.\n","Example output:\n","roasted, roasted\n","\"\"\"\n","\n","    resp = client.chat.completions.create(\n","        model=\"llama-3.1-8b-instant\",\n","        temperature=0,\n","        messages=[\n","            {\"role\": \"user\", \"content\": prompt}\n","        ]\n","    )\n","\n","    text = resp.choices[0].message.content.strip()\n","\n","    parts = [p.strip() for p in text.split(\",\")]\n","\n","    if len(parts) >= 2:\n","        return parts[0], parts[1]\n","\n","    return \"aromatic\", \"aromatic\"\n","\n","\n","with open(INPUT_PATH) as f:\n","    odorant_data = json.load(f)\n","\n","\n","docs = []\n","\n","for odorant, data in odorant_data.items():\n","\n","    foods = [normalize(f) for f in data.get(\"foods\", [])]\n","    descriptors = data.get(\"descriptors\", [])\n","\n","    if not foods:\n","        continue\n","\n","    foods_sample = foods[:8]\n","    desc_sample = descriptors[:6]\n","\n","    category1, category2 = generate_food_category(desc_sample, foods_sample)\n","\n","    text = f\"\"\"Odorant: {odorant}\n","\n","Aroma descriptors:\n","{\", \".join(desc_sample)}.\n","\n","This odorant appears in {category1} foods such as {\", \".join(foods_sample)}.\n","\n","Because it is shared across many {category2} ingredients,\n","it contributes to flavor compatibility between them.\n","\"\"\"\n","\n","    docs.append({\n","        \"id\": f\"odorant_{odorant}\",\n","        \"type\": \"odorant_profile\",\n","        \"odorant\": odorant,\n","        \"text\": text\n","    })\n","\n","\n","with open(OUTPUT_PATH, \"w\") as f:\n","    for doc in docs:\n","        f.write(json.dumps(doc) + \"\\n\")\n","\n","\n","print(f\"Saved {len(docs)} odorant RAG docs to {OUTPUT_PATH}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"YF1tN8XUPrWw","executionInfo":{"status":"ok","timestamp":1773391900690,"user_tz":420,"elapsed":1026831,"user":{"displayName":"Arin Agarwal","userId":"16343823264529643708"}},"outputId":"3992a08b-9174-4442-ac41-5fd98e0801d2"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["Saved 492 odorant RAG docs to /content/drive/MyDrive/Culinary Agent/rag_docs/odorant_docs.jsonl\n"]}]}]}